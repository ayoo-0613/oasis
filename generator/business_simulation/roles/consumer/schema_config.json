{
  "metadata": {
    "version": "2.0.0",
    "role": "consumer",
    "agent_id_prefix": "consumer",
    "generator_name": "consumer_generate",
    "description": "Theory-aligned v2 discrete schema for general consumer agent generation.",
    "output_groups": [
      "demographic",
      "behavioral_traits",
      "consumption_preferences"
    ],
    "enrichment": {
      "enabled_by_default": false,
      "hook_name": "enrich_agent_profile",
      "optional_output_fields": [
        "behavioral_summary",
        "persona_description",
        "narrative_profile"
      ]
    },
    "theory_notes": [
      "Involvement is modeled as an upstream driver of information search and decision-process style.",
      "Perceived risk remains an upstream driver of slower decision processes and greater reliance on trusted options.",
      "Perceived behavioral control is introduced as a first-class TPB-aligned psychographic construct.",
      "Novelty adoption uses the standard five diffusion-of-innovations adopter categories."
    ],
    "field_annotations": {
      "decision_speed": {
        "interpretation": "process_indicator",
        "note": "Retained for compatibility in v2. Interpret as a downstream decision-process outcome rather than a stable core trait."
      }
    }
  },
  "schema": {
    "age_group": ["18_24", "25_34", "35_44", "45_54", "55_64", "65_plus"],
    "sex": ["female", "male"],
    "income_group": ["low", "lower_middle", "upper_middle", "high"],
    "education_group": ["secondary_or_less", "vocational", "undergraduate", "postgraduate"],
    "occupation_group": ["student", "entry_level", "professional", "managerial", "retired", "homemaker", "unemployed"],
    "household_stage": ["single", "couple_no_children", "family_with_children", "empty_nest", "shared_household"],
    "region_group": ["metro", "suburban", "regional"],
    "involvement_level": ["low", "medium", "high"],
    "price_sensitivity": ["low", "medium", "high"],
    "quality_orientation": ["low", "medium", "high"],
    "risk_sensitivity": ["low", "medium", "high"],
    "novelty_adoption": ["innovator", "early_adopter", "early_majority", "late_majority", "laggard"],
    "social_influence_susceptibility": ["low", "medium", "high"],
    "perceived_behavioral_control": ["low", "medium", "high"],
    "purchase_planning_style": ["impulsive", "habitual", "limited_problem_solving", "extended_problem_solving"],
    "decision_speed": ["fast", "deliberate", "slow"],
    "brand_loyalty": ["low", "medium", "high"],
    "promotion_sensitivity": ["low", "medium", "high"],
    "information_search_depth": ["shallow", "moderate", "deep"],
    "channel_preference": ["store_first", "omnichannel", "digital_first"],
